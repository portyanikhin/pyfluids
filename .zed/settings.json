{
  "format_on_save": "on",
  "tab_size": 4,
  "languages": {
    "Python": {
      "language_servers": ["ruff", "ty"],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
    "JSON": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "JSONC": {
      "formatter": "prettier",
      "tab_size": 2,
    },
    "YAML": {
      "formatter": "prettier",
      "tab_size": 2,
    },
  },
}
